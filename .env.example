# Backend environment example for AIcork / Pairings API
#
# Copy this file to `.env` and fill in the values.
#
# IMPORTANT:
# - For Gmail, you must use an "App password", not your normal account password.
# - See: https://support.google.com/accounts/answer/185833

# ---------------------------------------------------------------------------
# Primary application DB (users/auth/cellar/history): PostgreSQL in production
# ---------------------------------------------------------------------------
# Example:
GOOGLE_API_KEY=your_google_api_key_here

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Gmail address used to send verification emails.
MAIL_USERNAME=your_gmail_address@gmail.com

# Gmail App Password (16-character string). NEVER commit the real value.
MAIL_PASSWORD=your_app_password_here

# From address shown in the email; usually the same as MAIL_USERNAME.
MAIL_FROM=Corkey Sommelier <your_gmail_address@gmail.com>

#DB setting
POSTGRES_PASSWORD=your_postgres_password_here

# JWT signing secret for auth tokens
SECRET_KEY=your_secret_key_here

APP_DATABASE_URL=postgresql+psycopg://corkey:your_postgres_password_here@localhost:5432/corkey   
#APP_DATABASE_URL=postgresql+psycopg://corkey:corkey_dev_password@corkey-postgres:5432/corkey

# AWS RDS CLoud
#APP_DATABASE_URL=postgresql+psycopg://corkey:corkeypassword!@corkey-db.cp4m0guieqod.us-east-2.rds.amazonaws.com:5432/wine_db

# Optional: base URL for password-reset links in logs / future emails.
PASSWORD_RESET_LINK_BASE=your_password_reset_link_base_here





